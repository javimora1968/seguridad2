n~" TYPE = string)  ARG(NAME = ~"usuario_ini~" TYPE = string)  ARG(NAME = ~"usuario_fin~" TYPE = string) " arguments=(("modulo_ini", string),("modulo_fin", string),("usuario_ini", string),("usuario_fin", string))  sort="id_modulo A id_usuario A opciones_por_modulo_consecutivo A " )
